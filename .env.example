# USHSS Portal — Environment (.env)
# Supabase SQL version

# App
SECRET_KEY=your-secret-key-here
DEBUG=True
CORS_ORIGINS=*
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_DB_PASSWORD=your-db-password-here

# Email notifications (optional) — Account Approved / Rejected messages.
# If SMTP_HOST is left unset, these emails are printed to the server
# console instead of sent (safe default for local/dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=USHSS Portal <no-reply@ushss.local>
SMTP_USE_TLS=true
