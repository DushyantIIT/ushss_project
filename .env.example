# Core app
SECRET_KEY=replace-with-a-strong-random-value
DEBUG=true
CORS_ORIGINS=*
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Supabase project (provided)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Backend-only key (recommended for server operations)
# SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# SQLAlchemy database URL (recommended explicit setting)
# DATABASE_URL=postgresql+psycopg2://postgres:<SUPABASE_DB_PASSWORD>@db.your-project-ref.supabase.co:5432/postgres

# Optional helper if DATABASE_URL is not set:
# SUPABASE_DB_PASSWORD=your-db-password
