# USHSS Portal — Environment Variables
# Copy this to .env and fill in the values

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production-must-be-32-chars

# Token expiry in minutes (default 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero config for dev):
DATABASE_URL=sqlite:///./ushss.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://ushss_user:strongpassword@localhost:5432/ushss_db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev only!
CORS_ORIGINS=*

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
